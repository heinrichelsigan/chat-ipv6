<configuration>
    <!--
        For a description of web.config changes see http://go.microsoft.com/fwlink/?LinkId=235367.

        The following attributes can be set on the <httpRuntime> tag.
        <system.Web>
            <httpRuntime targetFramework="4.6.2" />
        </system.Web>
    -->
	<configSections>
		<sectionGroup name="enyim.com">
			<section name="memcached" type="Enyim.Caching.Configuration.MemcachedClientSection, Enyim.Caching"/>
		</sectionGroup>
		<section
            name="clusterclient"
            type="Amazon.ElastiCacheCluster.ClusterConfigSettings, Amazon.ElastiCacheCluster" />
	</configSections>
	<clusterclient>
		<!-- the hostname and port values are from step 1 above -->
		<endpoint hostname="cachecqrxseu-53g0xw.serverless.eus2.cache.amazonaws.com" port="11211" />
	</clusterclient>
    <system.web>
	    <customErrors mode="Off" />
        <compilation debug="true" targetFramework="4.7.2" />
        <httpRuntime targetFramework="4.6.2" maxRequestLength="16777216" executionTimeout="3600" />
    </system.web>
	<appSettings>
		<!-- add key="AppDirPathWin" value="S:\chat-ipv6\C#\EU.CqrXs.CqrSrv\EU.CqrXs.CqrSrv.CqrJd\" /-->
		<!-- add key="BaseAppPathWin" value="/" /-->
		<!-- add key="ExternalClientIP" value="217.149.168.203" /-->
		<!-- add key="ExternalClientIP" value="2001:4bc9:a44:ef61:30eb:44c:7f86:378" /-->


		<add key="ServerIPv4" value="18.101.101.108" />
		<add key="ServerIPv6" value="2a05:d011:cdf:3a00:75d:d95d:136e:9e41" />

		<add key="AppUrl" value="https://cqrxs.eu/cqrsrv/cqrjd/" />
		<add key="AppDir" value="cqrsrv/cqrjd/" />
		<add key="AppDirPathUnix" value="/var/www/cqrsrv/cqrjd/" />
		<add key="BaseAppPathUnix" value="/cqrsrv/cqrjd/" />


		<add key="UseHttpApplicationState" value="true"/>
		<add key="UseAmazonElasticCache" value="false"/>
		<add key="SpoolerDirectory" value="/var/spool/cqrsrv/" />

		<!-- 		
		    <add key="ServerIPv4" value="15.188.56.225" />
		    <add key="ServerIPv6" value="2a05:d012:209:ee04:4dd9:b939:bc98:8080" />

